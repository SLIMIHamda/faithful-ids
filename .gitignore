# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# DVC-tracked payloads — pointers + manifests are committed, payloads are not.
# raw/corrected/processed/cache data blobs and run/model artifact payloads.
data/raw/**/*
!data/raw/**/.gitkeep
!data/raw/**/*.md
!data/raw/**/*.json
data/corrected/**/*
!data/corrected/**/.gitkeep
!data/corrected/**/*.md
!data/corrected/**/*.json
data/processed/**/*
!data/processed/**/.gitkeep
data/cache/**/*
!data/cache/**/.gitkeep

# Model payloads: manifests committed, weights DVC-tracked.
models/**/*.bin
models/**/*.pt
models/**/*.onnx

# Run payloads: MANIFEST.json + config.resolved.yaml + STATUS committed,
# large artifacts DVC-tracked.
runs/**/artifacts/**
runs/**/logs/**

# Toy smoke run + its stub LLM cache are regenerable CI fixtures — never committed.
runs/EXP-TOY-001/
runs/_*/

# Analysis output payloads (parquet); MANIFEST.json committed.
analysis/outputs/**/*.parquet

# Generated paper assets: the DETERMINISTIC representations are committed and
# diffed by figure-regen (the .data.json numeric sidecars and .tex tables).
# Rasterised images (.png/.pdf) are regenerable build products whose exact bytes
# depend on platform font rendering, so they are NOT version-controlled (see the
# tolerance policy in docs/reproducibility-guide.md).
paper/figures/generated/*.png
paper/figures/generated/*.pdf
paper/tables/generated/*.pdf

# Toy analysis outputs: results.json is deterministic (committed); the MANIFEST
# references the ephemeral toy run id, so it is not committed.
analysis/outputs/toy_demo/MANIFEST.json
analysis/outputs/toy_coverage/MANIFEST.json

# Pilot outputs are per-run, NON-CITABLE real results produced on Kaggle — never
# committed (reproduce them by running the pilot). Includes the run cache dirs.
analysis/outputs/pilot_faithfulness/
analysis/outputs/pilot_coverage/
paper/figures/generated/fig_pilot_*
paper/tables/generated/tab_pilot_*
runs/EXP-PILOT-001/
runs/_pilot_*/

# Environment fingerprints scratch
*.env-fingerprint.json

# OS
.DS_Store
Thumbs.db
