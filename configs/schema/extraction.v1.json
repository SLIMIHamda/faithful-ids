{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/schema/extraction.v1.json",
  "title": "Evaluation extractor config (firewall side B)",
  "description": "The extractor declares its own fixed model inline. model.model_family must be disjoint from every generator LLM family AND the VtE verifier family — checked by tools/firewall_check.py.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "kind", "version", "model", "rule_assisted", "prompt", "temperature", "audit_gate_ref"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "schema_version": {"const": "v1"},
    "kind": {"const": "extraction"},
    "version": {
      "type": "string",
      "description": "Instrument semver, stamped onto every ClaimSet as extractor_version. Bumps on ANY behaviour change (prompt OR rule-engine); distinct from prompt.version (the prompt-asset version).",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_family", "provider", "quantisation"],
      "properties": {
        "model_family": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "provider": {"enum": ["local_open_weights", "frontier_api"]},
        "quantisation": {"enum": ["none", "4bit"]},
        "weights": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["hf_repo", "revision", "sha256"],
          "properties": {
            "hf_repo": {"type": "string"},
            "revision": {"type": "string"},
            "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
          }
        }
      }
    },
    "rule_assisted": {"type": "boolean"},
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "sha256"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "temperature": {"const": 0},
    "audit_gate_ref": {"type": "string", "pattern": "^EXP-G-[0-9]{3}[A-Za-z0-9_-]*$"}
  }
}
