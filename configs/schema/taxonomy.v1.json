{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/schema/taxonomy.v1.json",
  "title": "Multi-class target taxonomy (single source of truth for class labels)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "kind", "dataset", "version", "canonical_classes", "label_map"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "schema_version": {"const": "v1"},
    "kind": {"const": "class_taxonomy"},
    "dataset": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "canonical_classes": {
      "type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}
    },
    "label_map": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    }
  }
}
