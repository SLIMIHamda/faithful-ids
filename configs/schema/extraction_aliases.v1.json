{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/schema/extraction_aliases.v1.json",
  "title": "Extractor paraphrase alias table (instrument asset)",
  "description": "Maps natural-language paraphrases to canonical feature names for the rule-assisted extractor. Hash-pinned from the extraction config; edits require an extractor instrument version bump.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "kind",
    "version",
    "aliases"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "schema_version": {
      "const": "v1"
    },
    "kind": {
      "const": "extraction_aliases"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 6
        }
      }
    }
  }
}
