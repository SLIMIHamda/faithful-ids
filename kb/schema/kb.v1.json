{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kb/schema/kb.v1.json",
  "title": "Knowledge-base entry file (feature semantics / attack classes)",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schema_version", "dataset", "version", "entries"],
  "properties": {
    "kind": {"enum": ["kb_feature_dictionary", "kb_attack_classes"]},
    "schema_version": {"const": "v1"},
    "dataset": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "units": {"type": ["string", "null"]},
          "range": {"type": ["array", "null"], "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
        }
      }
    }
  }
}
